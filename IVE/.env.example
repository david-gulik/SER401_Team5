# ---------------------------------------------------------------
# IVE / GAVEL environment configuration
# Copy this file to .env and fill in your values.
# .env is git-ignored and will never be committed.
# ---------------------------------------------------------------

# -- Canvas ----------------------------------------------------
# CANVAS_BASE_URL=https://canvas.asu.edu
# CANVAS_TOKEN=your_canvas_api_token_here

# -- ASU Roster ------------------------------------------------
# Auth method: "selenium" (opens browser for CAS + Duo MFA)
#              "cookies"  (uses exported cookie file, no browser)
# ROSTER_AUTH_METHOD=selenium

# Path to Netscape-format cookie file (required when auth=cookies)
# ROSTER_COOKIE_FILE=cookies.txt

# Pre-existing catalog API Bearer token (optional, skips Selenium
# for class lookup). Copy from browser dev tools on catalog.apps.asu.edu.
# ROSTER_TOKEN=

# -- ASU Roster timeouts (seconds) ----------------------------
# Time for user to complete CAS + Duo MFA in the browser
# ROSTER_MFA_TIMEOUT=120

# How long a cached session stays valid before re-authentication
# ROSTER_SESSION_TTL=600

# Timeout for individual HTTP requests (API calls, roster downloads)
# ROSTER_HTTP_TIMEOUT=30

# Time to wait for the catalog domain to load before seeding PKCE params
# ROSTER_PAGE_LOAD_TIMEOUT=30

# Time for the catalog SPA to exchange an OAuth code for a JWT
# ROSTER_TOKEN_EXCHANGE_TIMEOUT=30
